---
import "../styles/global.css";

const {
  title = "Thuna.Care — Continuous health monitoring for your family",
  description = "Twelve home visits a year, every reading reviewed by a doctor. Catch drift before symptoms — what an annual checkup never could. Now serving Dwarka and Faridabad.",
} = Astro.props;

// Canonical / social URL = the live deployment. When thuna.in is pointed at this
// repo, change `site` in astro.config to https://thuna.in and base to '/'.
const pageUrl = "https://thunacare-alt.github.io/thuna-site/";
const ogImage = pageUrl + "og-image.png";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={pageUrl} />
    <meta name="theme-color" content="#2563EB" />
    <meta name="color-scheme" content="light" />
    <meta name="author" content="Thuna Health" />
    <meta name="keywords" content="home health monitoring, preventive care, family health, Dwarka, Faridabad, home doctor visit, vitals at home, ECG at home, doctor review, continuous health monitoring India" />

    <!-- favicons -->
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="icon" type="image/x-icon" href="favicon.ico" />
    <link rel="apple-touch-icon" href="favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Thuna.Care" />
    <meta property="og:title" content="Thuna.Care — Care that stays with you" />
    <meta property="og:description" content="Continuous health monitoring for your family. Twelve home visits a year. Drift caught before symptoms. Now serving Dwarka and Faridabad." />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_IN" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Thuna.Care — Care that stays with you" />
    <meta name="twitter:description" content="Twelve home visits a year. Every reading reviewed by a doctor. Drift caught before symptoms. Continuous health monitoring for Indian families." />
    <meta name="twitter:image" content={ogImage} />

    <!-- fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
    />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "MedicalBusiness",
      name: "Thuna.Care",
      description: description,
      url: "https://thuna.in/",
      email: "care@thuna.in",
      telephone: "+91-88912-30464",
      priceRange: "₹₹",
      areaServed: { "@type": "Place", name: "Dwarka and Faridabad, India" },
      medicalSpecialty: "PreventiveMedicine",
      image: ogImage,
    })} />
  </head>
  <body>
    <a class="skip" href="#main">Skip to main content</a>
    <slot />
  </body>
</html>

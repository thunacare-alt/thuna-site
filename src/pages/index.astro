</Layout>

<style>
  /* ---------------- BRAND / NAV ---------------- */
  .nav { position: sticky; top: 0; z-index: 100; transition: background .3s, box-shadow .3s, border-color .3s; border-bottom: 1px solid transparent; }
  .nav[data-state="top"] { background: rgba(255,255,255,.6); backdrop-filter: blur(8px); }
  .nav[data-state="scrolled"] { background: rgba(255,255,255,.92); backdrop-filter: blur(12px); box-shadow: 0 1px 0 var(--border), 0 8px 30px rgba(15,23,42,.05); border-color: var(--border); }
  .nav__inner { display: flex; align-items: center; gap: 18px; height: 70px; }
  .brand { display: inline-flex; align-items: center; gap: 9px; text-decoration: none; }
  .brand__mark { display: grid; place-items: center; width: 30px; height: 30px; border-radius: 9px; background: linear-gradient(135deg, #2F6BF0, var(--blue-dark)); color: #fff; box-shadow: 0 4px 12px -3px rgba(37,99,235,.5); }
  .brand__mark svg { width: 18px; height: 18px; }
  .brand__word { font-weight: 800; font-size: 20px; letter-spacing: -0.04em; color: var(--ink); }
  .brand__dot { color: var(--blue); }
  .nav__links { display: flex; gap: 26px; margin-left: auto; }
  .nav__links a { text-decoration: none; color: var(--slate); font-size: 15px; font-weight: 500; transition: color .15s; }
  .nav__links a:hover { color: var(--ink); }
  .nav__cta { margin-left: 24px; }
  .nav__cta .btn { padding: 11px 20px; font-size: 14.5px; }
  .nav__burger { display: none; margin-left: auto; width: 44px; height: 44px; border: 1px solid var(--border); border-radius: 12px; background: #fff; flex-direction: column; align-items: center; justify-content: center; gap: 5px; }
  .nav__burger span { width: 18px; height: 2px; background: var(--ink); border-radius: 2px; transition: .25s; }
  .nav__burger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__burger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav__burger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .mobile-menu { display: flex; flex-direction: column; gap: 4px; padding: 10px var(--pad) 22px; background: #fff; border-bottom: 1px solid var(--border); }
  .mobile-menu a:not(.btn) { padding: 13px 6px; text-decoration: none; color: var(--ink); font-weight: 500; border-bottom: 1px solid var(--border); }
  .mobile-menu .btn { margin-top: 12px; }

  /* generic card */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-card); box-shadow: var(--sh-sm); }

  /* ---------------- HERO ---------------- */
  .hero { position: relative; overflow: clip; display: flex; flex-direction: column; min-height: clamp(560px, calc(100svh - 70px), 940px); padding-top: clamp(10px, 2vw, 24px); padding-bottom: clamp(16px, 2.5vw, 30px); }
  .hero__bg { position: absolute; inset: 0; z-index: -1; background:
    radial-gradient(52% 46% at 84% 4%, rgba(37,99,235,.08), transparent 70%),
    radial-gradient(46% 42% at 4% 96%, rgba(37,99,235,.05), transparent 70%),
    linear-gradient(180deg, #FBFDFF, #fff 55%); }
  .hero__top { display: flex; flex-wrap: wrap; align-items: flex-end; justify-content: space-between; gap: 20px 40px; padding-top: clamp(6px, 1.6vw, 18px); padding-bottom: clamp(18px, 2.6vw, 30px); }
  .hero__intro { max-width: 660px; }
  .hero__h1 { font-size: clamp(40px, 6.2vw, 74px); line-height: .98; margin: 16px 0 0; }
  .hero__sub { margin-top: 18px; font-size: clamp(16px, 1.5vw, 19px); color: var(--slate); max-width: 520px; }
  .hero__actions { display: flex; flex-direction: column; align-items: flex-start; gap: 13px; padding-bottom: 4px; }
  .hero__btns { display: flex; flex-wrap: wrap; gap: 12px; }
  .hero__note { font-size: 13.5px; color: var(--slate); font-weight: 500; }
  .hero__stage-wrap { flex: 1 1 auto; min-height: 440px; display: flex; }
  .hero-stage:focus-visible { outline: 3px solid var(--blue); outline-offset: 3px; }
  .hero-hint__arrow { display: inline-flex; animation: hintNudge 1.3s ease-in-out infinite; }
  @keyframes hintNudge { 0%,100%{ transform: translateX(0) } 50%{ transform: translateX(6px) } }
  @media (prefers-reduced-motion: reduce){ .hero-hint__arrow { animation: none; } }

  /* ---------------- OPENING ---------------- */
  .opening { padding-block: clamp(74px, 11vw, 150px); }
  .opening .eyebrow { margin-bottom: 26px; }
  .opening__line { max-width: 1000px; }
  .opening__sub { margin-top: 34px; max-width: 680px; font-size: clamp(18px, 2vw, 21px); line-height: 1.65; color: var(--slate); }
  .opening__sub strong { color: var(--ink); font-weight: 600; }

  /* ---------------- APP SHOWCASE ---------------- */
  .app__top { display: grid; grid-template-columns: 1fr 0.82fr; gap: clamp(32px, 6vw, 80px); align-items: center; }
  .app__copy h2 { margin: 18px 0 0; }
  .app__copy .lede { margin-top: 20px; font-size: clamp(17px, 1.9vw, 20px); color: var(--slate); line-height: 1.6; max-width: 520px; }
  .app__feats { list-style: none; margin: 28px 0 0; padding: 0; display: grid; gap: 14px; }
  .app__feats li { display: flex; gap: 12px; align-items: flex-start; font-size: 15.5px; color: var(--slate); }
  .app__feats li b { color: var(--ink); font-weight: 600; }
  .app__feats li span { flex: none; width: 22px; height: 22px; border-radius: 7px; background: var(--tint); color: var(--blue); display: grid; place-items: center; margin-top: 1px; }
  .app__feats li span svg { width: 14px; height: 14px; }
  .app__hero-phone { position: relative; display: flex; justify-content: center; }
  .app__hero-phone img { width: min(310px, 78%); height: auto; filter: drop-shadow(0 40px 60px rgba(15,23,42,.18)); border-radius: 38px; }
  .app__glow { position: absolute; inset: 0; z-index: -1; background: radial-gradient(50% 44% at 50% 42%, rgba(37,99,235,.20), transparent 70%); filter: blur(8px); }
  .app__gallery { display: grid; grid-template-columns: repeat(4, 1fr); gap: clamp(14px, 2vw, 26px); margin-top: clamp(40px, 6vw, 72px); }
  .app__screen { margin: 0; text-align: center; }

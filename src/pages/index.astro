  .app__screen:hover img { transform: translateY(-6px); }
  .app__screen figcaption { margin-top: 16px; display: flex; flex-direction: column; gap: 3px; }
  .app__screen figcaption b { font-size: 15px; color: var(--ink); font-weight: 700; }
  .app__screen figcaption span { font-size: 13px; color: var(--slate); max-width: 220px; margin-inline: auto; line-height: 1.4; }
  .app__note { text-align: center; margin-top: 34px; font-size: 13px; color: var(--slate-soft); }

  /* ---------------- VALUE PROPS ---------------- */
  .props { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .prop-card { padding: 30px 28px; transition: transform .25s, box-shadow .25s, border-color .25s; }
  .prop-card:hover { transform: translateY(-4px); box-shadow: var(--sh-look); border-color: var(--tint-edge); }
  .prop-card__icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 13px; background: var(--tint); color: var(--blue); margin-bottom: 18px; }
  .prop-card__icon svg { width: 24px; height: 24px; }
  .prop-card h3 { margin-bottom: 9px; }
  .prop-card p { color: var(--slate); font-size: 15.5px; }

  /* ---------------- STEPS ---------------- */
  .steps { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: repeat(2, 1fr); gap: 18px 22px; }
  .step { display: flex; gap: 20px; padding: 26px 24px; transition: transform .25s, box-shadow .25s; }
  .step:hover { transform: translateY(-3px); box-shadow: var(--sh-look); }
  .step__n { font-size: 18px; font-weight: 800; color: var(--blue); flex: none; width: 44px; height: 44px; border-radius: 12px; background: var(--tint); display: grid; place-items: center; letter-spacing: -0.02em; }
  .step__top { display: flex; flex-wrap: wrap; align-items: baseline; gap: 8px 12px; margin-bottom: 7px; }
  .step__time { font-size: 12px; font-weight: 600; letter-spacing: .02em; text-transform: uppercase; color: var(--blue); background: var(--tint); padding: 3px 9px; border-radius: 100px; }
  .step__body p { color: var(--slate); font-size: 15px; }

  /* ---------------- MEASURE ---------------- */
  .measure { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
  .measure-col { padding: 32px 30px; }
  .measure-col__head { display: flex; flex-wrap: wrap; align-items: center; gap: 12px; margin-bottom: 8px; }
  .measure-col__sub { color: var(--slate); font-size: 15px; margin-bottom: 22px; }
  .pill { font-size: 12px; font-weight: 600; letter-spacing: .01em; padding: 6px 12px; border-radius: 100px; }
  .pill--blue { background: var(--blue); color: #fff; }
  .pill--ghost { background: var(--tint); color: var(--blue); }
  .chips { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 10px; }
  .chip { display: inline-flex; align-items: center; gap: 8px; padding: 10px 16px; border-radius: 100px; background: var(--tint); color: var(--blue-dark); font-weight: 600; font-size: 14.5px; }
  .chip__i { display: grid; place-items: center; width: 16px; height: 16px; color: var(--blue); }
  .chip__i svg { width: 14px; height: 14px; }
  .chip--more { background: var(--blue); color: #fff; }
  .chip--outline { background: #fff; border: 1px solid var(--border); color: var(--ink); }

  /* ---------------- CASE (light cinematic) ---------------- */
  .prevent { background: linear-gradient(180deg, #fff, #F2F6FE); }
  .case { display: grid; grid-template-columns: 1.1fr 1fr; gap: 22px; }
  .case__chart, .case__story { padding: 28px 30px; }
  .case__meta { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; font-size: 13px; color: var(--slate); margin-bottom: 18px; font-weight: 500; }
  .case__svg { width: 100%; height: 190px; }
  .case__line { transition: stroke-dashoffset 1.7s cubic-bezier(.4,0,.1,1); }
  .reveal.in .case__line { stroke-dashoffset: 0; }
  .case__dot { opacity: 0; transition: opacity .4s ease 1.4s; }
  .reveal.in .case__dot { opacity: 1; }
  .case__legend { display: flex; flex-wrap: wrap; gap: 18px; margin-top: 16px; font-size: 13px; color: var(--slate); }
  .lg { display: inline-block; width: 18px; height: 4px; border-radius: 2px; vertical-align: middle; margin-right: 6px; }
  .lg--stable { background: var(--slate-soft); } .lg--drift { background: var(--blue); }
  .case__flag { display: flex; flex-direction: column; gap: 10px; padding-bottom: 20px; margin-bottom: 20px; border-bottom: 1px solid var(--border); }
  .case__flag-pill { align-self: flex-start; background: var(--tint); color: var(--blue-dark); font-weight: 700; font-size: 13px; padding: 6px 13px; border-radius: 100px; }
  .case__flag p { color: var(--ink); font-size: 16px; } .case__flag strong { color: var(--blue); }
  .case__timeline { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 14px; }
  .case__timeline li { display: flex; flex-direction: column; gap: 2px; padding-left: 18px; position: relative; }
  .case__timeline li::before { content: ""; position: absolute; left: 0; top: 6px; width: 8px; height: 8px; border-radius: 50%; background: var(--blue); }
  .case__timeline li:not(:last-child)::after { content: ""; position: absolute; left: 3.5px; top: 14px; bottom: -14px; width: 1px; background: var(--border); }
  .case__tag { font-weight: 700; font-size: 13.5px; color: var(--ink); }
  .case__d { font-size: 14.5px; color: var(--slate); }

  /* HOW / scroll-flow styles live in global.css (they target React-island DOM) */

  /* ---------------- QUOTES ---------------- */
  .quotes { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .quote { margin: 0; padding: 30px 28px; display: flex; flex-direction: column; }
  .quote blockquote { margin: 0 0 22px; font-size: 18px; line-height: 1.55; color: var(--ink); font-weight: 500; letter-spacing: -0.01em; }
  .quote figcaption { margin-top: auto; display: flex; flex-direction: column; }
  .quote__n { font-weight: 700; color: var(--blue); }
  .quote__m { font-size: 14px; color: var(--slate); }

  /* ---------------- PRICING ---------------- */
  .plans { display: grid; grid-template-columns: 1.05fr 1fr; gap: 22px; align-items: start; }
  .plan { position: relative; padding: 34px 32px; border-radius: var(--r-hero); }
  .plan--feature { background: linear-gradient(150deg, #2F6BF0, var(--blue-dark)); color: #fff; box-shadow: var(--sh-blue); }
  .plan--feature h3, .plan--feature .plan__price .amt { color: #fff; }
  .plan__flag { display: inline-block; font-size: 12px; font-weight: 600; color: #fff; background: rgba(255,255,255,.18); padding: 5px 13px; border-radius: 100px; margin-bottom: 18px; }
  .plan__flag--ghost { background: var(--tint); color: var(--blue); }
  .plan h3 { font-size: 24px; }
  .plan__price { display: flex; align-items: baseline; gap: 8px; margin-top: 14px; }
  .plan__price .amt { font-size: 50px; font-weight: 800; color: var(--ink); letter-spacing: -.03em; }
  .plan__price .per { color: rgba(255,255,255,.78); font-size: 15px; font-weight: 500; }
  .plan:not(.plan--feature) .plan__price .per { color: var(--slate); }
  .plan__sub { font-size: 14.5px; margin-top: 6px; color: rgba(255,255,255,.78); }
  .plan:not(.plan--feature) .plan__sub { color: var(--slate); }
  .plan__cta { width: 100%; margin: 22px 0 8px; }
  .plan__list { list-style: none; margin: 14px 0 0; padding: 18px 0 0; border-top: 1px solid rgba(255,255,255,.2); display: flex; flex-direction: column; gap: 13px; }
  .plan:not(.plan--feature) .plan__list { border-top-color: var(--border); }
  .plan__list li { display: flex; gap: 11px; align-items: flex-start; font-size: 15px; }
  .plan--feature .plan__list li { color: rgba(255,255,255,.92); }
  .plan:not(.plan--feature) .plan__list li { color: var(--slate); }
  .plan__list li span { flex: none; margin-top: 3px; }
  .plan--feature .plan__list li span { color: #fff; }
  .plan:not(.plan--feature) .plan__list li span { color: var(--blue); }
  .plan__list li span svg { width: 16px; height: 16px; }

  .compare { margin-top: 26px; padding: 28px 30px; }
  .compare__head { font-weight: 700; color: var(--ink); margin-bottom: 16px; }
  .compare__list { list-style: none; margin: 0 0 16px; padding: 0; display: flex; flex-direction: column; }
  .compare__list li { display: flex; justify-content: space-between; gap: 16px; padding: 11px 0; border-bottom: 1px dashed var(--border); font-size: 15px; color: var(--slate); }
  .compare__list li b { color: var(--ink); font-weight: 700; white-space: nowrap; }
  .compare__foot { font-size: 15.5px; color: var(--slate); } .compare__foot b { color: var(--blue); }
  .finely { margin-top: 18px; font-size: 12.5px; color: var(--slate-soft); line-height: 1.6; max-width: 820px; }

  /* ---------------- AREA ---------------- */
  .area { display: grid; grid-template-columns: 1.1fr .9fr; gap: clamp(28px,5vw,56px); align-items: center; }
  .area__stats { display: flex; flex-wrap: wrap; gap: 30px; margin: 28px 0 22px; }
  .area__stats b { display: block; font-size: 34px; font-weight: 800; color: var(--blue); line-height: 1; letter-spacing: -.03em; }
  .area__stats span { font-size: 13.5px; color: var(--slate); }
  .area__note { font-size: 15px; color: var(--slate); } .area__note a { color: var(--blue); font-weight: 600; }
  .area__chips { display: flex; flex-wrap: wrap; gap: 12px; }
  .area-chip { display: inline-flex; align-items: center; gap: 9px; padding: 13px 20px; border-radius: 100px; background: var(--page); border: 1px solid var(--border); font-weight: 600; color: var(--ink); font-size: 15.5px; }
  .area-chip span { color: var(--blue); display: inline-flex; } .area-chip svg { width: 17px; height: 17px; }

  /* ---------------- FAQ ---------------- */
  .faq { max-width: 820px; }
  .faq__list { border-top: 1px solid var(--border); }
  .faq__item { border-bottom: 1px solid var(--border); }
  .faq__item summary { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 22px 4px; font-size: clamp(17px,2.2vw,20px); color: var(--ink); font-weight: 700; letter-spacing: -0.02em; }
  .faq__item summary::-webkit-details-marker { display: none; }
  .faq__plus { position: relative; flex: none; width: 22px; height: 22px; }
  .faq__plus::before, .faq__plus::after { content: ""; position: absolute; background: var(--blue); border-radius: 2px; transition: transform .25s; }
  .faq__plus::before { left: 0; top: 10px; width: 22px; height: 2px; }
  .faq__plus::after { left: 10px; top: 0; width: 2px; height: 22px; }
  .faq__item[open] .faq__plus::after { transform: rotate(90deg); opacity: 0; }
  .faq__a { padding: 0 4px 24px; max-width: 700px; }
  .faq__a p { color: var(--slate); font-size: 16px; }
  .faq__item[open] summary { color: var(--blue); }

  /* ---------------- CONTACT (blue) ---------------- */
  .section--cta { background: linear-gradient(150deg, #2F6BF0 0%, var(--blue-dark) 100%); position: relative; overflow: clip; }
  .section--cta::after { content: ""; position: absolute; top: -160px; right: -120px; width: 460px; height: 460px; border-radius: 50%; background: radial-gradient(circle, rgba(255,255,255,.14), transparent 70%); }
  .cta { text-align: center; position: relative; z-index: 1; }
  .cta__copy { max-width: 660px; margin-inline: auto; }
  .cta h2 { color: #fff; font-size: clamp(32px,5vw,52px); }
  .cta .eyebrow { justify-content: center; color: #fff; } .cta .eyebrow::before { background: #fff; }
  .cta .lede { color: rgba(255,255,255,.85); margin-inline: auto; }
  .cta__actions { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; margin-top: 30px; }
  .cta__mail { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,.34); }
  .cta__mail:hover { background: rgba(255,255,255,.1); }
  .cta__shield { display: inline-flex; align-items: center; gap: 9px; margin-top: 24px; font-size: 13.5px; color: rgba(255,255,255,.8); }
  .cta__shield svg { width: 16px; height: 16px; }

  /* ---------------- FOOTER ---------------- */
  .footer { background: #0B1220; color: #94A3B8; padding: clamp(48px,6vw,72px) 0 30px; }
  .footer__inner { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 36px; }
  .brand--light .brand__word { color: #fff; }
  .footer__brand p { margin-top: 16px; font-size: 14.5px; max-width: 320px; line-height: 1.6; }
  .footer__col h4 { font-size: 12px; text-transform: uppercase; letter-spacing: .08em; color: #64748B; margin: 0 0 16px; font-weight: 700; }
  .footer__col a { display: flex; align-items: center; gap: 9px; text-decoration: none; color: #CBD5E1; font-size: 14.5px; padding: 6px 0; transition: color .15s; }
  .footer__col a:hover { color: #fff; }
  .footer__col a svg { width: 16px; height: 16px; flex: none; }
  .footer__base { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; margin-top: 40px; padding-top: 22px; border-top: 1px solid rgba(255,255,255,.08); font-size: 13px; color: #64748B; }

  /* ---------------- STICKY CTA ---------------- */
  .sticky-cta { position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 90; display: none; align-items: center; justify-content: space-between; gap: 14px; padding: 12px 14px 12px 20px; background: #fff; border: 1px solid var(--border); border-radius: 16px; box-shadow: var(--sh-md); animation: slideUp .35s ease; }
  .sticky-cta__txt { display: flex; flex-direction: column; line-height: 1.2; }
  .sticky-cta__txt b { font-size: 18px; color: var(--ink); font-weight: 800; letter-spacing: -0.02em; }
  .sticky-cta__txt span { font-size: 12.5px; color: var(--slate); }
  .sticky-cta .btn { padding: 12px 18px; font-size: 14.5px; white-space: nowrap; }
  @keyframes slideUp { from { transform: translateY(120%); } to { transform: none; } }

  /* ---------------- FILM MODAL ---------------- */
  .film-modal { position: fixed; inset: 0; z-index: 200; display: grid; place-items: center; padding: 20px; }
  .film-modal__backdrop { position: absolute; inset: 0; background: rgba(15,23,42,.74); backdrop-filter: blur(6px); animation: fadeIn .3s ease; }
  .film-modal__box { position: relative; width: min(960px, 96vw); border-radius: 18px; overflow: hidden; box-shadow: var(--sh-md); background: #0B1220; animation: popIn .35s cubic-bezier(.2,.8,.2,1); }
  .film-modal__box video { width: 100%; display: block; aspect-ratio: 16/9; background: #0B1220; }
  .film-modal__close { position: absolute; top: 10px; right: 10px; z-index: 2; width: 42px; height: 42px; border-radius: 50%; border: none; background: rgba(255,255,255,.16); color: #fff; font-size: 22px; line-height: 1; cursor: pointer; backdrop-filter: blur(6px); }
  .film-modal__close:hover { background: rgba(255,255,255,.3); }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }
  @keyframes popIn { from{opacity:0; transform: scale(.94)} to{opacity:1; transform:none} }

  /* ---------------- RESPONSIVE ---------------- */
  @media (max-width: 980px) {
    .nav__links, .nav__cta { display: none; }
    .nav__burger { display: flex; }
    .hero__top { flex-direction: column; align-items: flex-start; }
    .hero__actions { align-items: flex-start; width: 100%; }
    .app__top { grid-template-columns: 1fr; gap: 36px; }
    .app__hero-phone { order: -1; }
    .app__gallery { grid-template-columns: repeat(2, 1fr); }
    .props, .quotes { grid-template-columns: 1fr; }
    .measure, .case, .plans, .area { grid-template-columns: 1fr; }
    .footer__inner { grid-template-columns: 1fr 1fr; }
    .footer__brand { grid-column: 1 / -1; }
  }
  @media (max-width: 600px) {
    .sticky-cta { display: flex; }
    main { padding-bottom: 76px; }
    .hero { min-height: auto; }
    .hero__stage-wrap { min-height: 380px; }
    .hero__btns { width: 100%; }
    .hero__btns .btn { flex: 1 1 auto; justify-content: center; }
    .cta__actions .btn, .cta__actions { width: 100%; }
    .app__gallery { grid-template-columns: 1fr 1fr; gap: 18px; }
    .footer__inner { grid-template-columns: 1fr; gap: 26px; }
    .footer__base { justify-content: flex-start; }
    .plan__price .amt { font-size: 42px; }
  }
</style>

<script>
  // nav scroll state
  const nav = document.getElementById('nav');
  const onScroll = () => nav?.setAttribute('data-state', window.scrollY > 12 ? 'scrolled' : 'top');
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // mobile menu
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => { menu.hidden = true; burger?.setAttribute('aria-expanded', 'false'); })
  );

  // "Watch the film" modal
  const filmBtn = document.getElementById('watchFilm');
  const filmModal = document.getElementById('filmModal');
  const filmVideo = document.getElementById('filmVideo');
  const openFilm = () => { if (!filmModal) return; filmModal.hidden = false; document.body.style.overflow = 'hidden'; if (filmVideo) { filmVideo.currentTime = 0; filmVideo.play().catch(() => {}); } };
  const closeFilm = () => { if (!filmModal) return; filmModal.hidden = true; document.body.style.overflow = ''; if (filmVideo) filmVideo.pause(); };
  filmBtn?.addEventListener('click', openFilm);
  filmModal?.querySelectorAll('[data-close]').forEach((el) => el.addEventListener('click', closeFilm));
  window.addEventListener('keydown', (e) => { if (e.key === 'Escape' && filmModal && !filmModal.hidden) closeFilm(); });

  // scroll reveal
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { rootMargin: '0px 0px -8% 0px', threshold: 0.06 });
  document.querySelectorAll('.reveal:not(.in)').forEach((el) => io.observe(el));

  // sticky CTA after hero
  const sticky = document.getElementById('stickyCta');
  const hero = document.querySelector('.hero');
  if (sticky && hero) {
    const so = new IntersectionObserver((entries) => { entries.forEach((e) => { sticky.hidden = e.isIntersecting; }); }, { threshold: 0, rootMargin: '-40% 0px 0px 0px' });
    so.observe(hero);
  }

  // count-up stats
  const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const countEls = document.querySelectorAll('.count');
  const fmt = (el, v) => `${el.dataset.prefix || ''}${v}${el.dataset.suffix || ''}`;
  const runCount = (el) => {
    const to = parseFloat(el.dataset.to || '0');
    if (reduceMotion) { el.textContent = fmt(el, to); return; }
    const dur = 1100; const start = performance.now();
    const step = (now) => {
      const t = Math.min(1, (now - start) / dur);
      const e = 1 - Math.pow(1 - t, 3);
      el.textContent = fmt(el, Math.round(to * e));
      if (t < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  };
  const co = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { runCount(e.target); co.unobserve(e.target); } });
  }, { threshold: 0.6 });
  countEls.forEach((el) => co.observe(el));

  // test hook: ?flow= scrolls to (and freezes) the story flow for screenshots
  const flowParam = new URLSearchParams(location.search).get('flow');
  if (flowParam != null) {
    const goFlow = () => { const el = document.querySelector('.flow'); if (el) window.scrollTo(0, el.offsetTop + 24); };
    window.addEventListener('load', () => setTimeout(goFlow, 80));
  }

  // Lenis smooth scroll (skipped for reduced motion and the ?flow screenshot hook)
  if (!reduceMotion && flowParam == null) {
    import('lenis').then(({ default: Lenis }) => {
      const lenis = new Lenis({ duration: 1.05, smoothWheel: true, lerp: 0.1 });
      const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
      requestAnimationFrame(raf);
      document.querySelectorAll('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (ev) => {
          const id = a.getAttribute('href');
          if (!id || id === '#') return;
          const target = document.querySelector(id);
          if (target) { ev.preventDefault(); lenis.scrollTo(target, { offset: -70 }); }
        });
      });
    }).catch(() => {});
  }
</script>

  const onScroll = () => nav?.setAttribute('data-state', window.scrollY > 12 ? 'scrolled' : 'top');
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // --- mobile menu ---
  const burger = document.getElementById('burger');
  const menu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = burger.getAttribute('aria-expanded') === 'true';
    burger.setAttribute('aria-expanded', String(!open));
    if (menu) menu.hidden = open;
  });
  menu?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => { menu.hidden = true; burger?.setAttribute('aria-expanded', 'false'); })
  );

  // --- hero video: muted autoplay + sound toggle + mobile source swap ---
  const video = document.getElementById('heroVideo');
  const frame = document.getElementById('videoFrame');
  const toggle = document.getElementById('soundToggle');
  const ICON_ON = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>`;
  const ICON_OFF = `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="22" x2="16" y1="9" y2="15"/><line x1="16" x2="22" y1="9" y2="15"/></svg>`;

  if (video) {
    // use the vertical cut on small portrait screens for better framing
    if (window.matchMedia('(max-width: 600px)').matches) {
      video.setAttribute('src', 'hero-mobile.mp4');
      frame?.classList.add('is-portrait');
      video.load();
    }
    video.muted = true;
    const tryPlay = () => video.play().catch(() => {});
    tryPlay();
    video.addEventListener('loadeddata', tryPlay, { once: true });

    toggle?.addEventListener('click', () => {
      video.muted = !video.muted;
      if (!video.muted) tryPlay();
      const muted = video.muted;
      toggle.innerHTML = muted ? ICON_OFF : ICON_ON;
      toggle.setAttribute('aria-pressed', String(!muted));
      toggle.setAttribute('aria-label', muted ? 'Unmute video' : 'Mute video');
    });
  }

  // --- scroll reveal ---
  const io = new IntersectionObserver((entries) => {
    entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { rootMargin: '0px 0px -8% 0px', threshold: 0.06 });
  document.querySelectorAll('.reveal:not(.in)').forEach((el) => io.observe(el));

  // --- sticky CTA: show after hero scrolls out (small screens) ---
  const sticky = document.getElementById('stickyCta');
  const hero = document.querySelector('.hero');
  if (sticky && hero) {
    const so = new IntersectionObserver((entries) => {
      entries.forEach((e) => { sticky.hidden = e.isIntersecting; });
    }, { threshold: 0, rootMargin: '-40% 0px 0px 0px' });
    so.observe(hero);
  }
</script>

---
import Layout from "../layouts/Layout.astro";

// ---- contact ----
const PHONE = "919810519812"; // +91 98105 19812
const EMAIL = "care@thuna.in";
const wa = (msg) => `https://wa.me/${PHONE}?text=${encodeURIComponent(msg)}`;
const WA_BOOK = wa("Hi Thuna — I'd like to book a home visit. My city + household size: ");
const WA_ANNUAL = wa("Hi Thuna — I'd like to start the annual plan (₹500/month). My city + household size: ");
const WA_SINGLE = wa("Hi Thuna — I'd like to book a single home visit (₹500). My city + household size: ");

// ---- inline icons (lucide-style) ----
const I = {
  whatsapp: `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.62-5.962C.122 5.281 5.4 0 12.057 0c3.262 0 6.323 1.27 8.624 3.575 2.3 2.302 3.57 5.364 3.568 8.624 0 6.654-5.282 11.934-11.934 11.934a11.86 11.86 0 01-5.71-1.456L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.392 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.83 9.83 0 001.516 5.26l-.999 3.648 3.972-1.607zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.247-.694.247-1.289.173-1.413z"/></svg>`,
  arrow: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>`,
  check: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>`,
  mail: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>`,
  pulse: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>`,
  users: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  route: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="6" cy="19" r="3"/><path d="M9 19h8.5a3.5 3.5 0 0 0 0-7h-11a3.5 3.5 0 0 1 0-7H15"/><circle cx="18" cy="5" r="3"/></svg>`,
  pin: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>`,
  shield: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10"/></svg>`,
  volOff: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="22" x2="16" y1="9" y2="15"/><line x1="16" x2="22" y1="9" y2="15"/></svg>`,
  volOn: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg>`,
};

// ---- content data ----
const steps = [
  { n: "01", t: "A companion arrives", time: "Monthly, at home", d: "Background-checked, ID-verified, trained in our six-week home-care protocol. The same familiar faces every month — not a different stranger each time." },
  { n: "02", t: "A few simple questions", time: "First 5 minutes", d: "We start with a short profile: how you've been, sleep, diet, anything new since last visit. The context that numbers alone can't show." },
  { n: "03", t: "Vitals at the dining table", time: "~15 minutes", d: "Blood pressure, ECG, blood glucose, SpO₂, temperature, pulse and weight — recorded into your family's record and explained as we go." },
  { n: "04", t: "Labs at home, only when needed", time: "When a trend flags", d: "If something is drifting, a registered Nursing Assistant draws bloods at home and we order the right test from an NABL-accredited partner lab. Never on a fixed calendar." },
  { n: "05", t: "An MD reviews every reading", time: "Same day", d: "Each reading lands beside your last eleven. An MD reviews the trend virtually the same day and flags anything drifting — before symptoms appear." },
  { n: "06", t: "The whole family follows along", time: "Within the hour", d: "A plain-language summary lands in your family's WhatsApp and in the app. Everyone stays in the loop — no panic, just continuity." },
];

const props = [
  { icon: I.pulse, t: "Continuous, not episodic", d: "Twelve readings a year per parameter, not one. We replace the annual snapshot with a year-long trend line." },
  { icon: I.users, t: "The family, not the individual", d: "One household, one record, one monthly visit — up to four members. Health you finally talk about together." },
  { icon: I.route, t: "Routed, not abandoned", d: "Drift detected → a virtual MD or a partner lab, the same week, at member rates. A number is never left for you to decode alone." },
];

const vitalsEvery = ["Blood Pressure", "Pulse + ECG", "SpO₂", "Temperature", "Blood Glucose", "BMI + Waist", "Haemoglobin"];
const vitalsTrigger = ["HbA1c (3-mo sugar)", "Lipid profile", "Kidney function", "Liver function", "Thyroid (TSH)", "Urine routine", "Vitamin D + B12"];

const caseTimeline = [
  { tag: "Visit 12 · Day 0", d: "141 / 88 mmHg. Drift flagged: +15% over four months." },
  { tag: "MD review · same day", d: "Same-day virtual review. Orders HbA1c + lipids." },
  { tag: "Partner lab · Day 4", d: "HbA1c 6.1 (prediabetic). Lipids elevated. Drawn at home." },
  { tag: "Doctor consult · Day 9", d: "Lifestyle plan started. No medication needed." },
];

const testimonials = [
  { q: "My father's BP was drifting up over our first months with Thuna. The doctor caught it — and routed us to a tele-consult before any symptoms. We changed his meds. That's the entire point.", n: "Anita R.", m: "Family of 4" },
  { q: "Felt expensive at first. Then we did the maths: one ICU night in this city is a year of Thuna. My wife and I don't queue up for hospital checkups any more.", n: "Vikram J.", m: "Family of 3" },
  { q: "What I didn't expect: the WhatsApp summaries. My mother reads them. My sister reads them. We finally talk about my parents' health as a family — not in a panic.", n: "Priya M.", m: "Family of 5" },
];

const areas = ["Dwarka", "Gurugram", "South Delhi", "Noida", "Faridabad"];

const annualIncludes = [
  "Up to 4 family members covered",
  "12 home visits a year",
  "Continuous monitoring + longitudinal record",
  "Same-day virtual MD review of every reading",
  "Member-rate doctor consults + partner labs",
  "Family report on WhatsApp + emergency routing",
];
const singleIncludes = [
  "1 home visit · readings for up to 2 people",
  "1 MD follow-up call within the week",
  "Same-day virtual MD review of every reading",
  "Convert to the annual plan anytime",
];

const faqs = [
  { q: "Why subscription, not pay-per-visit?", a: "Because prevention is a trend, not a snapshot. A subscription means twelve visits a year, so every reading lands beside your last eleven — that's what lets us catch drift before it becomes a diagnosis. Pay-per-visit gives you a number; the annual plan gives you a story. You can still try us with a single visit first, and convert anytime." },
  { q: "Who actually visits the home?", a: "A trained companion — background-checked, ID-verified and put through our six-week home-care protocol. You see the same faces each visit. When blood needs to be drawn, a registered Nursing Assistant attends instead. Every reading is then reviewed by an MD virtually, the same day." },
  { q: "Which areas do you serve?", a: "We're live across the NCR region — including Dwarka, Gurugram, South Delhi, Noida and Faridabad, with companions active in 11 sectors and an average travel radius of about 30 minutes. Tell us your locality on WhatsApp and we'll confirm the next available slot." },
  { q: "Is my family's data private?", a: "Yes. Thuna is DPDPA-compliant. Your records are consented, structured and used only to track your health over time and flag drift for MD review. Lab work runs through NABL-accredited partner labs, and we never sell your data." },
  { q: "What about doctor consults and lab tests?", a: "They sit on top of the subscription at member rates — discounted versus market and billed only when used. If a trend flags something, we line up a virtual doctor consult (from ₹299) or order the right deeper test from an NABL-accredited partner lab (HbA1c from ₹349, lipid profile from ₹399), often drawn at home. Only when your trend warrants it — never a fixed schedule." },
  { q: "What if there's an emergency?", a: "Emergency ambulance routing is included (partner-billed), and if a reading needs urgent attention our MD review flags it the same day and routes you onward. Thuna is preventive monitoring, not a 24/7 emergency room — but you're never left to interpret a worrying number on your own." },
  { q: "How does cancellation work?", a: "Cancel anytime — there's no lock-in. The annual plan is the best way to build a longitudinal record, and the single-visit option lets you try Thuna once before committing to the year." },
];
---

<Layout>
  <!-- ============== HEADER ============== -->
  <header class="nav" id="nav" data-state="top">
    <div class="wrap nav__inner">
      <a class="brand" href="#top" aria-label="Thuna.Care home">
        <img src="favicon.svg" alt="" width="34" height="34" />
        <span>Thuna<span class="brand__dot">.</span>Care</span>
      </a>
      <nav class="nav__links" aria-label="Primary">
        <a href="#how">How it works</a>
        <a href="#measure">What we measure</a>
        <a href="#prevent">Prevention</a>
        <a href="#pricing">Pricing</a>
        <a href="#faq">FAQ</a>
      </nav>
      <div class="nav__cta">
        <a class="btn btn--primary" href={WA_BOOK} set:html={`${I.whatsapp}<span>Book a visit</span>`}></a>
      </div>
      <button class="nav__burger" id="burger" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
        <span></span><span></span><span></span>
      </button>
    </div>
    <div class="mobile-menu" id="mobile-menu" hidden>
      <a href="#how">How it works</a>
      <a href="#measure">What we measure</a>
      <a href="#prevent">Prevention</a>
      <a href="#pricing">Pricing</a>
      <a href="#faq">FAQ</a>
      <a class="btn btn--primary btn--lg" href={WA_BOOK} set:html={`${I.whatsapp}<span>Book a visit</span>`}></a>
    </div>
  </header>

  <main id="main">
    <span id="top"></span>

    <!-- ============== HERO ============== -->
    <section class="hero">
      <div class="hero__bg" aria-hidden="true"></div>
      <div class="wrap hero__grid">
        <div class="hero__copy reveal in">
          <span class="eyebrow">Thuna.Care · Now serving NCR</span>
          <h1>Care that <span class="accent-it">stays&nbsp;with&nbsp;you.</span></h1>
          <p class="hero__sub">
            A Thuna companion visits your home every month — vitals checked, every reading
            reviewed by an MD, your whole family in the loop. Preventive care that catches
            small changes early, long before they become an emergency.
          </p>
          <div class="hero__cta">
            <a class="btn btn--primary btn--lg" href={WA_BOOK} set:html={`${I.whatsapp}<span>Book a visit</span>`}></a>
            <a class="btn btn--ghost btn--lg" href="#how" set:html={`<span>See how it works</span>${I.arrow}`}></a>
          </div>
          <p class="hero__note">₹500 / month&nbsp; · &nbsp;Twelve home visits a year&nbsp; · &nbsp;Cancel anytime</p>
        </div>

        <figure class="hero__media reveal in">
          <div class="video-frame" id="videoFrame">
            <video
              id="heroVideo"
              src="hero.mp4"
              poster="hero-poster.jpg"
              muted
              loop
              autoplay
              playsinline
              preload="metadata"
              aria-label="Thuna.Care — a companion visiting a family at home"
            ></video>
            <button class="sound-toggle" id="soundToggle" type="button" aria-pressed="false" aria-label="Unmute video" set:html={I.volOff}></button>
            <div class="video-frame__badge"><span class="dot"></span> 35-sec film</div>
          </div>
        </figure>
      </div>

      <!-- trust strip -->
      <div class="wrap">
        <p class="trustline reveal">
          <strong>Twelve home visits a year, every reading reviewed by an MD.</strong>
          Catch drift before symptoms — what an annual checkup never could.
        </p>
      </div>
    </section>

    <!-- ============== VALUE PROPS ============== -->
    <section class="section" id="why">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">Why continuous, not annual</span>
          <h2>Indian families are checked <span class="accent-it">once a year</span>, when disease moves every month.</h2>
          <p class="lede">Almost every chronic disease that kills Indians under 60 — hypertension, diabetes, kidney drift, lipid disorders — is invisible for years before it shows. An annual checkup sees one snapshot and misses the eleven months in between. Thuna replaces the snapshot with a trend line.</p>
        </div>
        <div class="props">
          {props.map((p) => (
            <article class="prop-card reveal">
              <span class="prop-card__icon" set:html={p.icon}></span>
              <h3>{p.t}</h3>
              <p>{p.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ============== HOW IT WORKS ============== -->
    <section class="section section--cream" id="how">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">How it works</span>
          <h2>What every monthly visit <span class="accent-it">looks like.</span></h2>
          <p class="lede">Continuous care isn't an app — it's someone showing up at your dining table. Every visit follows the same protocol; every reading lands in your family's longitudinal record.</p>
        </div>
        <ol class="steps">
          {steps.map((s) => (
            <li class="step reveal">
              <div class="step__n">{s.n}</div>
              <div class="step__body">
                <div class="step__top">
                  <h3>{s.t}</h3>
                  <span class="step__time">{s.time}</span>
                </div>
                <p>{s.d}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ============== WHAT WE MEASURE ============== -->
    <section class="section" id="measure">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">What we measure</span>
          <h2>Snapshots give you a number. <span class="accent-it">Trends tell the story.</span></h2>
          <p class="lede">Continuous vitals at every visit, deeper labs only when your trend asks for them — never on a fixed calendar you don't need.</p>
        </div>
        <div class="measure">
          <div class="measure-col reveal">
            <div class="measure-col__head">
              <h3>Every visit</h3>
              <span class="pill pill--green">12× a year · included</span>
            </div>
            <p class="measure-col__sub">Captured at home, beside your last eleven readings.</p>
            <ul class="chips">
              {vitalsEvery.map((v) => (<li class="chip"><span class="chip__i" set:html={I.check}></span>{v}</li>))}
              <li class="chip chip--more">&amp; more</li>
            </ul>
          </div>
          <div class="measure-col reveal">
            <div class="measure-col__head">
              <h3>On trigger</h3>
              <span class="pill pill--coral">Only when your trend flags · member rate</span>
            </div>
            <p class="measure-col__sub">When drift is detected, we order the right deeper test from an NABL-accredited partner lab — never a fixed schedule. You never pay for tests you don't need.</p>
            <ul class="chips">
              {vitalsTrigger.map((v) => (<li class="chip chip--outline">{v}</li>))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ============== PREVENTION / CASE STUDY ============== -->
    <section class="section section--green" id="prevent">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">The catch</span>
          <h2>What our model saw <span class="accent-it">before symptoms.</span></h2>
          <p class="lede">Each reading lands beside the last eleven. Drift-detection compares against the household's own baseline — not population averages — and flags what an MD reviews the same day. One real case, April 2026.</p>
        </div>

        <div class="case reveal">
          <div class="case__chart">
            <div class="case__meta">
              <span>Systolic BP · mmHg · 12 months</span>
              <span>Member · age 58 · NCR</span>
            </div>
            <svg class="case__svg" viewBox="0 0 520 200" preserveAspectRatio="none" role="img" aria-label="A blood-pressure trend line: nine stable months, then a three-month upward drift that is flagged.">
              <defs>
                <linearGradient id="fill" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0" stop-color="#C97B5C" stop-opacity="0.28"/>
                  <stop offset="1" stop-color="#C97B5C" stop-opacity="0"/>
                </linearGradient>
              </defs>
              <line x1="0" y1="150" x2="520" y2="150" stroke="rgba(255,255,255,.16)" stroke-dasharray="4 6"/>
              <path d="M0 138 L70 140 L140 134 L210 138 L280 132 L350 120 L420 96 L490 70 L520 58" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M0 138 L70 140 L140 134 L210 138 L280 132 L350 120 L420 96 L490 70 L520 58 L520 200 L0 200 Z" fill="url(#fill)"/>
              <circle cx="490" cy="70" r="6" fill="#C97B5C" stroke="#fff" stroke-width="2"/>
            </svg>
            <div class="case__legend">
              <span><i class="lg lg--stable"></i> 9 stable months — within baseline</span>
              <span><i class="lg lg--drift"></i> 3-month drift — +15% vs. baseline</span>
            </div>
          </div>

          <div class="case__story">
            <div class="case__flag">
              <span class="case__flag-pill">⚑ Flagged</span>
              <p>Caught <strong>~14 months earlier</strong> than a typical annual checkup would have — before symptoms ever appeared.</p>
            </div>
            <ol class="case__timeline">
              {caseTimeline.map((c) => (
                <li><span class="case__tag">{c.tag}</span><span class="case__d">{c.d}</span></li>
              ))}
            </ol>
          </div>
        </div>
      </div>
    </section>

    <!-- ============== TESTIMONIALS ============== -->
    <section class="section" id="stories">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">Why members renewed</span>
          <h2>What 500+ households <span class="accent-it">told us.</span></h2>
          <p class="lede">Feedback from quarterly review calls. Names changed for privacy on request.</p>
        </div>
        <div class="quotes">
          {testimonials.map((t) => (
            <figure class="quote reveal">
              <blockquote>“{t.q}”</blockquote>
              <figcaption><span class="quote__n">{t.n}</span><span class="quote__m">{t.m}</span></figcaption>
            </figure>
          ))}
        </div>
      </div>
    </section>

    <!-- ============== PRICING ============== -->
    <section class="section section--cream" id="pricing">
      <div class="wrap">
        <div class="section-head reveal">
          <span class="eyebrow">Pricing</span>
          <h2>One household. <span class="accent-it">₹500 a month.</span></h2>
          <p class="lede">The annual plan is the product — it's how we build your family's longitudinal record. A single visit exists for households who want to try us once first.</p>
        </div>

        <div class="plans">
          <article class="plan plan--feature reveal">
            <div class="plan__flag">How most families join</div>
            <h3>Annual subscription</h3>
            <div class="plan__price"><span class="amt">₹500</span><span class="per">/ month</span></div>
            <p class="plan__sub">Billed ₹6,000 / year per household · no-cost EMI available</p>
            <a class="btn btn--primary btn--lg plan__cta" href={WA_ANNUAL} set:html={`${I.whatsapp}<span>Start the year</span>`}></a>
            <ul class="plan__list">
              {annualIncludes.map((x) => (<li><span set:html={I.check}></span>{x}</li>))}
            </ul>
          </article>

          <article class="plan reveal">
            <div class="plan__flag plan__flag--ghost">Try us once</div>
            <h3>Single visit</h3>
            <div class="plan__price"><span class="amt">₹500</span><span class="per">/ visit · up to 2 people</span></div>
            <p class="plan__sub">Pay per visit · convert to annual anytime</p>
            <a class="btn btn--ghost btn--lg plan__cta" href={WA_SINGLE} set:html={`<span>Book one visit</span>${I.arrow}`}></a>
            <ul class="plan__list">
              {singleIncludes.map((x) => (<li><span set:html={I.check}></span>{x}</li>))}
            </ul>
          </article>
        </div>

        <div class="compare reveal">
          <p class="compare__head">What you'd otherwise spend</p>
          <ul class="compare__list">
            <li><span>One ICU night in Delhi-NCR</span><b>₹40,000–1,00,000</b></li>
            <li><span>Annual master health checkup × 4</span><b>₹24,000+</b></li>
            <li><span>Concierge home doctor visit (one-off)</span><b>₹2,500–4,000</b></li>
          </ul>
          <p class="compare__foot">Annual Thuna for a household: <b>₹6,000</b> — effectively ₹500 a month. No insurance markup, no hospital admin overhead.</p>
        </div>
        <p class="finely">Lab tests run through NABL-accredited partner labs. Doctor consults are virtual, conducted by partner MDs. Thuna does not provide insurance products. Pricing is exclusive of GST where applicable.</p>
      </div>
    </section>

    <!-- ============== SERVICE AREA ============== -->
    <section class="section" id="area">
      <div class="wrap area">
        <div class="area__copy reveal">
          <span class="eyebrow">Service area</span>
          <h2>Now serving the <span class="accent-it">NCR region.</span></h2>
          <p class="lede">Real households, real visits, real longitudinal records — across the National Capital Region.</p>
          <div class="area__stats">
            <div><b>500+</b><span>households</span></div>
            <div><b>11</b><span>active sectors</span></div>
            <div><b>~30 min</b><span>avg travel radius</span></div>
          </div>
          <p class="area__note">Not sure if we're in your sector yet? <a href={WA_BOOK}>Message us</a> — we're expanding across NCR.</p>
        </div>
        <div class="area__chips reveal">
          {areas.map((a) => (<span class="area-chip"><span set:html={I.pin}></span>{a}</span>))}
        </div>
      </div>
    </section>

    <!-- ============== FAQ ============== -->

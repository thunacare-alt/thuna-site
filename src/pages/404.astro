---
// Branded 404 — GitHub Pages serves /thuna-site/404.html for any unknown path
// under the project. Uses absolute links/styles so it works at any depth.
const home = "/thuna-site/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found — Thuna.Care</title>
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#1B4332" />
    <link rel="icon" type="image/svg+xml" href="/thuna-site/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,420..560;1,9..144,440..520&family=Inter:wght@400;500;600&display=swap"
    />
    <style>
      :root { --green: #1B4332; --coral: #C97B5C; --ink: #19211C; --muted: #6B716A; }
      * { box-sizing: border-box; }
      body {
        margin: 0; min-height: 100vh; display: grid; place-items: center; text-align: center;
        font-family: "Inter", system-ui, sans-serif; color: var(--ink);
        background: radial-gradient(60% 60% at 50% 18%, rgba(27,67,50,.07), transparent 70%), linear-gradient(180deg, #FBF8F2, #fff 60%);
        padding: 40px 22px;
      }
      .wrap { max-width: 460px; }
      .badge { display:inline-flex; align-items:center; gap:9px; font-size:12.5px; font-weight:600; letter-spacing:.14em; text-transform:uppercase; color: var(--green); }
      .badge::before { content:""; width:7px; height:7px; border-radius:50%; background: var(--coral); }
      h1 { font-family: "Fraunces", Georgia, serif; font-weight: 460; font-size: clamp(40px, 9vw, 68px); margin: 18px 0 0; letter-spacing:-.02em; }
      h1 em { font-style: italic; color: var(--green); }
      p { color: var(--muted); font-size: 17px; margin: 16px 0 30px; line-height: 1.6; }
      .btn { display:inline-flex; align-items:center; gap:9px; background: var(--green); color:#fff; text-decoration:none; font-weight:600; font-size:15.5px; padding:14px 26px; border-radius:100px; transition: transform .18s, box-shadow .25s; box-shadow:0 6px 18px rgba(27,67,50,.22); }
      .btn:hover { transform: translateY(-2px); box-shadow:0 12px 28px rgba(27,67,50,.30); }
      .btn svg { width:18px; height:18px; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <span class="badge">Thuna.Care</span>
      <h1>Page <em>not&nbsp;found.</em></h1>
      <p>That page slipped off the chart. Let's get you back to where care stays with you.</p>
      <a class="btn" href={home}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to home
      </a>
    </main>
  </body>
</html>

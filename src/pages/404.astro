---
// Branded 404 — GitHub Pages serves /404.html for any unknown path on the domain.
const home = "/";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Page not found — thuna.care</title>
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#2563EB" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800&display=swap"
    />
    <style>
      :root { --blue: #2563EB; --ink: #0F172A; --slate: #64748B; }
      * { box-sizing: border-box; }
      body {
        margin: 0; min-height: 100vh; display: grid; place-items: center; text-align: center;
        font-family: "Inter", system-ui, sans-serif; color: var(--ink);
        background: radial-gradient(60% 60% at 50% 16%, rgba(37,99,235,.08), transparent 70%), linear-gradient(180deg, #FBFDFF, #fff 60%);
        padding: 40px 22px;
      }
      .wrap { max-width: 460px; }
      .badge { display:inline-flex; align-items:center; gap:9px; font-size:12px; font-weight:700; letter-spacing:.12em; text-transform:uppercase; color: var(--blue); }
      .badge::before { content:""; width:7px; height:7px; border-radius:50%; background: var(--blue); }
      h1 { font-weight: 800; font-size: clamp(42px, 9vw, 70px); margin: 18px 0 0; letter-spacing:-.035em; line-height: 1; }
      h1 em { font-style: normal; color: var(--blue); }
      p { color: var(--slate); font-size: 17px; margin: 16px 0 30px; line-height: 1.6; }
      .btn { display:inline-flex; align-items:center; gap:9px; background: linear-gradient(135deg,#2F6BF0,#1D4ED8); color:#fff; text-decoration:none; font-weight:600; font-size:15.5px; padding:14px 26px; border-radius:100px; transition: transform .18s, box-shadow .25s; box-shadow:0 8px 20px -8px rgba(37,99,235,.55); }
      .btn:hover { transform: translateY(-2px); box-shadow:0 16px 34px -12px rgba(37,99,235,.5); }
      .btn svg { width:18px; height:18px; }
    </style>
  </head>
  <body>
    <main class="wrap">
      <span class="badge">thuna.care</span>
      <h1>Page <em>not&nbsp;found.</em></h1>
      <p>That page slipped off the chart. Let's get you back to where care stays with you.</p>
      <a class="btn" href={home}>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
        Back to home
      </a>
    </main>
  </body>
</html>
